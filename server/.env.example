# Copy to .env for local development
# On Railway, set these as environment variables in the dashboard

# PostgreSQL connection string (Railway provides this automatically
# when you add a Postgres plugin — copy the DATABASE_URL from there)
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# Strong random secret for JWT signing (generate with: openssl rand -hex 32)
JWT_SECRET="change-me-to-a-long-random-secret"

# Port (Railway sets this automatically, no need to set manually)
PORT=3001

# Set to production on Railway
NODE_ENV="production"
