{
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm install && npm run build && npm install --prefix server"
  },
  "deploy": {
    "startCommand": "npm run start",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 30,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
